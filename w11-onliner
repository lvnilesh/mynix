#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<EOF
Usage: $0 [--force] [--fresh] [--disk-bus virtio|sata] [--drivers-iso /path/virtio-win.iso] [--auto-drivers]
  --force         Undefine existing domain if present, keep disk/NVRAM.
  --fresh         Undefine domain and delete disk + NVRAM, recreate clean (implies --force).
  --disk-bus      Primary system disk bus (virtio for performance, sata for built-in Windows driver). Default: virtio.
  --drivers-iso   Attach a secondary CDROM with virtio drivers (virtio-win ISO). Recommended when using --disk-bus virtio.
  --auto-drivers  Automatically download/cache latest virtio-win ISO into /var/lib/libvirt/boot and attach.
  --arch          CPU architecture: x64 or arm64 (default: auto-detect from host).
  --post-install   Wait for guest agent, then enable OpenSSH Server (PowerShell default), RDP, and firewall rules.
  --user NAME      Local account username for unattended install (default: cloudgenius).
  --password PASS   Password for the local account. If omitted, prompts interactively.
  --hostname NAME    Windows computer name (default: win11).
  --no-autounattend  Skip autounattend.xml generation (manual OOBE).
If domain exists and no flags: attempt to start it.
Examples:
  $0 --fresh                            # Fresh install with virtio + auto drivers + local account.
  $0 --fresh --disk-bus sata            # Simpler install, no extra drivers needed.
  $0 --fresh --no-autounattend          # Fresh install, manual OOBE.
  $0 --post-install                     # Enable SSH+RDP on running VM.
  $0 --fresh --user admin               # Custom local account name.
  $0 --fresh --password s3cret --post-install  # Fully non-interactive.
EOF
}

FORCE=0
FRESH=0
DISK_BUS="virtio"
DRIVERS_ISO=""
AUTO_DRIVERS=0
ARCH_OVERRIDE=""
POST_INSTALL=0
LOCAL_USER="cloudgenius"
LOCAL_PASS=""
HOSTNAME_OVERRIDE="win11"
NO_AUTOUNATTEND=0
while [[ $# -gt 0 ]]; do
  case "$1" in
    --force) FORCE=1; shift;;
    --fresh) FORCE=1; FRESH=1; shift;;
    --disk-bus)
      [[ $# -ge 2 ]] || { echo "--disk-bus needs value" >&2; exit 1; }
      DISK_BUS="$2"; shift 2;
      case "$DISK_BUS" in virtio|sata) ;; *) echo "Invalid --disk-bus: $DISK_BUS" >&2; exit 1;; esac ;;
  --drivers-iso)
      [[ $# -ge 2 ]] || { echo "--drivers-iso needs path" >&2; exit 1; }
      DRIVERS_ISO="$2"; shift 2;;
  --auto-drivers) AUTO_DRIVERS=1; shift;;
  --post-install) POST_INSTALL=1; shift;;
  --user)
      [[ $# -ge 2 ]] || { echo "--user needs value" >&2; exit 1; }
      LOCAL_USER="$2"; shift 2;;
  --password)
      [[ $# -ge 2 ]] || { echo "--password needs value" >&2; exit 1; }
      LOCAL_PASS="$2"; shift 2;;
  --hostname)
      [[ $# -ge 2 ]] || { echo "--hostname needs value" >&2; exit 1; }
      HOSTNAME_OVERRIDE="$2"; shift 2;;
  --no-autounattend) NO_AUTOUNATTEND=1; shift;;
  --arch)
      [[ $# -ge 2 ]] || { echo "--arch needs value" >&2; exit 1; }
      ARCH_OVERRIDE="$2"; shift 2;
      case "$ARCH_OVERRIDE" in x64|arm64) ;; *) echo "Invalid --arch: $ARCH_OVERRIDE (use x64 or arm64)" >&2; exit 1;; esac ;;
    -h|--help) usage; exit 0;;
    *) echo "Unknown arg: $1" >&2; usage; exit 1;;
  esac
done

# Windows 11 virt-install helper (stable firmware paths, TPM 2.0, Secure Boot)
# Specs: 16 GiB RAM, 1 socket / 8 cores / 1 thread (8 vCPUs), 200G qcow2 disk
# Requirements:
#  * Groups: user is in kvm,libvirt
#  * Firmware symlinks from Nix config: /etc/ovmf/OVMF_CODE.ms.fd & /etc/ovmf/OVMF_VARS.ms.fd
#  * ISO path below exists

VM_NAME="${HOSTNAME_OVERRIDE:-win11}"
DOWNLOAD_BASE="https://download.i.cloudgenius.app/Windows"
DOWNLOAD_DIR="/home/cloudgenius/Downloads"

# Detect architecture
if [[ -n "${ARCH_OVERRIDE:-}" ]]; then
  W11_ARCH="$ARCH_OVERRIDE"
else
  case "$(uname -m)" in
    x86_64)  W11_ARCH="x64" ;;
    aarch64) W11_ARCH="arm64" ;;
    *)       echo "Unknown host arch $(uname -m), use --arch x64|arm64" >&2; exit 1 ;;
  esac
fi
echo "Target architecture: $W11_ARCH" >&2

ISO=$(ls -1 "$DOWNLOAD_DIR"/Win11_*_English_${W11_ARCH}*.iso 2>/dev/null | sort -V | tail -n1 || true)
if [[ -z "$ISO" ]]; then
  echo "No local Win11 $W11_ARCH ISO, checking $DOWNLOAD_BASE/ ..." >&2
  _remote_iso=$(curl -fsSL "$DOWNLOAD_BASE/" | grep -Eo "Win11_[^\"]+_English_${W11_ARCH}[^\"]*\.iso" | sort -V | tail -n1 || true)
  if [[ -z "$_remote_iso" ]]; then echo "No Win11 $W11_ARCH ISO found locally or remote" >&2; exit 1; fi
  echo "Downloading $_remote_iso ..." >&2
  curl -fSL -o "$DOWNLOAD_DIR/$_remote_iso" "$DOWNLOAD_BASE/$_remote_iso"
  ISO="$DOWNLOAD_DIR/$_remote_iso"
fi
echo "Using Windows ISO: $ISO" >&2
DISK="/var/lib/libvirt/images/${VM_NAME}.qcow2"
DISK_SIZE_GB=200
NVRAM="/var/lib/libvirt/qemu/nvram/${VM_NAME}_VARS.fd"
CODE_FW="/etc/ovmf/OVMF_CODE.ms.fd"
VARS_TMPL="/etc/ovmf/OVMF_VARS.ms.fd"

# Determine libvirt runtime ownership (NixOS may run qemu as root)
if id libvirt-qemu >/dev/null 2>&1; then
  VM_USER=libvirt-qemu
else
  VM_USER=root
fi
if getent group libvirt >/dev/null 2>&1; then
  VM_GROUP=libvirt
elif getent group kvm >/dev/null 2>&1; then
  VM_GROUP=kvm
else
  VM_GROUP=root
fi

if [[ ! -f "$ISO" ]]; then
  echo "ISO not found: $ISO" >&2; exit 1
fi
if (( AUTO_DRIVERS )); then
  BOOT_DIR="/var/lib/libvirt/boot"
  sudo install -d -m0755 "$BOOT_DIR"
  if ! command -v curl >/dev/null 2>&1; then echo "curl required for --auto-drivers" >&2; exit 1; fi
  echo "Fetching latest virtio-win ISO URL..." >&2
  VIRTIO_ISO_URL="https://fedorapeople.org/groups/virt/virtio-win/direct-downloads/latest-virtio/"
  HTML=$(curl -fsSL "$VIRTIO_ISO_URL" || true)
  LATEST=$(echo "$HTML" | grep -Eo 'virtio-win-[0-9]+\.[0-9]+\.[0-9]+\.iso' | sort -V | tail -n1 || true)
  if [[ -z "$LATEST" ]]; then
    echo "Could not determine latest virtio-win ISO (network or layout change)." >&2; exit 1
  fi
  DRIVERS_ISO="$BOOT_DIR/$LATEST"
  if [[ ! -f "$DRIVERS_ISO" ]]; then
    echo "Downloading $LATEST ..." >&2
    curl -fSL -o "/tmp/$LATEST" "$VIRTIO_ISO_URL$LATEST"
    sudo mv "/tmp/$LATEST" "$DRIVERS_ISO"
  else
    echo "Using cached $DRIVERS_ISO" >&2
  fi
fi

if [[ -n "$DRIVERS_ISO" && ! -f "$DRIVERS_ISO" ]]; then
  echo "Drivers ISO not found: $DRIVERS_ISO" >&2; exit 1
fi
# Auto-fetch virtio drivers when using virtio disk bus
if [[ "$DISK_BUS" == "virtio" && -z "$DRIVERS_ISO" ]]; then
  BOOT_DIR="/var/lib/libvirt/boot"
  sudo install -d -m0755 "$BOOT_DIR"
  # Check local cache first
  _cached=$(ls -1 "$BOOT_DIR"/virtio-win-*.iso 2>/dev/null | sort -V | tail -n1 || true)
  if [[ -n "$_cached" ]]; then
    echo "Using cached virtio drivers: $(basename "$_cached")" >&2
    DRIVERS_ISO="$_cached"
  else
    echo "Virtio disk bus requires drivers. Fetching latest virtio-win ISO..." >&2
    VIRTIO_ISO_URL="https://fedorapeople.org/groups/virt/virtio-win/direct-downloads/latest-virtio/"
    HTML=$(curl -fsSL "$VIRTIO_ISO_URL" || true)
    LATEST=$(echo "$HTML" | grep -Eo 'virtio-win-[0-9]+\.[0-9]+\.[0-9]+\.iso' | sort -V | tail -n1 || true)
    if [[ -z "$LATEST" ]]; then
      echo "Could not determine latest virtio-win ISO. Use --disk-bus sata or supply --drivers-iso." >&2; exit 1
    fi
    echo "Downloading $LATEST ..." >&2
    curl -fSL -o "/tmp/$LATEST" "$VIRTIO_ISO_URL$LATEST"
    sudo mv "/tmp/$LATEST" "$BOOT_DIR/$LATEST"
    DRIVERS_ISO="$BOOT_DIR/$LATEST"
  fi
fi
for f in "$CODE_FW" "$VARS_TMPL"; do
  [[ -f $f ]] || { echo "Missing firmware file: $f" >&2; exit 1; }
done

sudo install -d -m0755 /var/lib/libvirt/images
sudo install -d -m0750 -o "$VM_USER" -g "$VM_GROUP" /var/lib/libvirt/qemu/nvram

if (( FRESH )); then
  echo "Fresh mode: removing existing disk & NVRAM (if they exist)." >&2
  sudo rm -f "$DISK" "$NVRAM" || true
fi

if [[ ! -f "$DISK" ]]; then
  echo "Creating disk $DISK (${DISK_SIZE_GB}G)";
  sudo qemu-img create -f qcow2 "$DISK" "${DISK_SIZE_GB}G" >/dev/null
fi

# Do NOT pre-create NVRAM; let libvirt clone from template to avoid master var store errors.
if [[ -f "$NVRAM" ]]; then
  echo "Existing NVRAM file present (will reuse if template attribute matches): $NVRAM";
fi

VM_EXISTS=0
VM_RUNNING=0
if sudo virsh -c qemu:///system dominfo "$VM_NAME" &>/dev/null; then
  VM_EXISTS=1
  _state=$(sudo virsh -c qemu:///system domstate "$VM_NAME" 2>/dev/null || true)
  [[ "$_state" == *running* ]] && VM_RUNNING=1
fi

if (( VM_EXISTS && VM_RUNNING && !FORCE && !FRESH )); then
  echo "Domain $VM_NAME is already running." >&2
  if (( POST_INSTALL )); then
    # Skip to post-install below
    :
  else
    echo "Nothing to do. Use --force to recreate, or --post-install to provision." >&2
    exit 0
  fi
elif (( VM_EXISTS && FORCE )); then
  echo "Undefining existing domain $VM_NAME (force=${FORCE}, fresh=${FRESH})." >&2
  sudo virsh -c qemu:///system destroy "$VM_NAME" &>/dev/null || true
  sudo virsh -c qemu:///system undefine "$VM_NAME" --nvram || sudo virsh -c qemu:///system undefine "$VM_NAME" || true
  VM_EXISTS=0; VM_RUNNING=0
elif (( VM_EXISTS && !VM_RUNNING && !FORCE )); then
  echo "Domain $VM_NAME exists but is stopped; starting it." >&2
  sudo virsh -c qemu:///system start "$VM_NAME"
  VM_RUNNING=1
fi

# Create and start VM if it doesn't exist (after possible undefine above)
if (( !VM_EXISTS )); then

# Generate autounattend.xml with local account (bypass Microsoft account)
