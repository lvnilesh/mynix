      <backend type='emulator' version='2.0'/>
    </tpm>
    <input type='tablet' bus='usb'/>
    <input type='keyboard' bus='usb'/>
    <graphics type='vnc' port='-1' autoport='yes' listen='0.0.0.0'/>
    <video><model type='qxl' ram='65536' vram='65536' vgamem='16384' heads='1'/></video>
    <channel type='unix'>
      <target type='virtio' name='org.qemu.guest_agent.0'/>
    </channel>
    <rng model='virtio'>
      <backend model='random'>/dev/urandom</backend>
    </rng>
$(
  if [[ -n "$FLOPPY_IMG" ]]; then
    cat <<FLOPPY
    <disk type='file' device='floppy'>
      <driver name='qemu' type='raw'/>
      <source file='$FLOPPY_IMG'/>
      <target dev='fda' bus='fdc'/>
      <readonly/>
    </disk>
FLOPPY
  fi)
  </devices>
</domain>
EOF

echo "Defining domain via virsh XML: $TMP_XML"
sudo virsh -c qemu:///system define "$TMP_XML" >/dev/null
echo "Starting domain $VM_NAME"
if ! sudo virsh -c qemu:///system start "$VM_NAME"; then
  echo "Start failed. Attempting fallback: remove stale NVRAM and recreate via template." >&2
  sudo rm -f "$NVRAM" || true
  # Regenerate XML with same template attribute
  sudo virsh -c qemu:///system undefine "$VM_NAME" --nvram || true
  sudo virsh -c qemu:///system define "$TMP_XML" >/dev/null
  if sudo virsh -c qemu:///system start "$VM_NAME"; then
    echo "VM $VM_NAME started after NVRAM fallback."
    VM_RUNNING=1
  else
    echo "Failed again after fallback." >&2; exit 1
  fi
fi
echo "VM $VM_NAME started. Connect with: virt-viewer --connect qemu:///system $VM_NAME"
  VM_RUNNING=1
fi  # end of !VM_EXISTS block

# --- Post-install provisioning ---
if (( POST_INSTALL )); then
  echo "Waiting for guest agent (this may take a few minutes on first boot)..." >&2
  for i in $(seq 1 90); do
    if sudo virsh qemu-agent-command "$VM_NAME" '{"execute":"guest-ping"}' &>/dev/null; then
      echo "Guest agent responding." >&2
      break
    fi
    sleep 5
  done
  if ! sudo virsh qemu-agent-command "$VM_NAME" '{"execute":"guest-ping"}' &>/dev/null; then
    echo "Guest agent not available after timeout. Install qemu-ga inside Windows first." >&2
    exit 1
  fi

  run_ps() {
    local cmd="$1"
    local label="${2:-}"
    local timeout="${3:-120}"
    [[ -n "$label" ]] && echo "  $label ..." >&2
    # Escape backslashes for JSON
    local escaped_cmd="${cmd//\\/\\\\}"
    local json="{\"execute\":\"guest-exec\",\"arguments\":{\"path\":\"powershell.exe\",\"arg\":[\"-NoProfile\",\"-Command\",\"${escaped_cmd}\"],\"capture-output\":true}}"
    local result
    result=$(sudo virsh qemu-agent-command "$VM_NAME" "$json" 2>&1) || { echo "  FAILED: $result" >&2; return 1; }
    local pid
    pid=$(echo "$result" | grep -o '"pid":[0-9]*' | cut -d: -f2)
    # Poll until command finishes
    local elapsed=0
    while (( elapsed < timeout )); do
      sleep 3
      elapsed=$((elapsed + 3))
      local status
      status=$(sudo virsh qemu-agent-command "$VM_NAME" "{\"execute\":\"guest-exec-status\",\"arguments\":{\"pid\":$pid}}" 2>/dev/null || true)
      if echo "$status" | grep -q '"exited":true'; then
        local exit_code
        exit_code=$(echo "$status" | grep -o '"exitcode":[0-9]*' | cut -d: -f2)
        if [[ "$exit_code" != "0" && -n "$exit_code" ]]; then
          local err_b64
          err_b64=$(echo "$status" | grep -o '"err-data":"[^"]*"' | cut -d'"' -f4)
          [[ -n "$err_b64" ]] && echo "    stderr: $(echo "$err_b64" | base64 -d 2>/dev/null)" >&2
        fi
        return "${exit_code:-0}"
      fi
    done
    echo "  TIMEOUT after ${timeout}s" >&2
    return 1
  }

  echo "Configuring OpenSSH Server (idempotent)..." >&2
  run_ps "if ((Get-WindowsCapability -Online -Name OpenSSH.Server~~~~0.0.1.0).State -ne 'Installed') { Add-WindowsCapability -Online -Name OpenSSH.Server~~~~0.0.1.0; 'INSTALLED' } else { 'ALREADY_INSTALLED' }" "Installing OpenSSH Server" 180
  run_ps "if ((Get-Service sshd -ErrorAction SilentlyContinue).Status -ne 'Running') { Start-Service sshd } ; Set-Service -Name sshd -StartupType Automatic" "Starting sshd"
  run_ps "New-ItemProperty -Path 'HKLM:\\SOFTWARE\\OpenSSH' -Name DefaultShell -Value 'C:\\Windows\\System32\\WindowsPowerShell\\v1.0\\powershell.exe' -PropertyType String -Force" "Setting PowerShell as default SSH shell"
  run_ps "if (-not (Get-NetFirewallRule -Name OpenSSH-Server -ErrorAction SilentlyContinue)) { netsh advfirewall firewall add rule name=OpenSSH-Server dir=in action=allow protocol=TCP localport=22; 'ADDED' } else { 'ALREADY_EXISTS' }" "Firewall rule for SSH"

  echo "Enabling Remote Desktop (idempotent)..." >&2
  run_ps "Set-ItemProperty -Path 'HKLM:\System\CurrentControlSet\Control\Terminal Server' -Name fDenyTSConnections -Value 0" "Enabling RDP registry"
  run_ps "Set-Service -Name SessionEnv -StartupType Automatic; Set-Service -Name TermService -StartupType Automatic; Set-Service -Name UmRdpService -StartupType Automatic" "Setting RDP services to auto-start"
  run_ps "Set-NetFirewallRule -DisplayGroup 'Remote Desktop' -Profile Any -Enabled True" "Firewall rule for RDP (all profiles)"
  run_ps "Set-NetConnectionProfile -NetworkCategory Private" "Setting network to Private"
  # RDP services may need a reboot to fully start via guest agent; schedule if not listening
  run_ps "if (-not (Test-NetConnection -ComputerName localhost -Port 3389 -InformationLevel Quiet -WarningAction SilentlyContinue)) { shutdown /r /t 10 /c 'Reboot for RDP activation'; 'REBOOT_SCHEDULED' } else { 'RDP_LISTENING' }" "Verifying RDP listener" 30

  echo "Removing Windows bloatware..." >&2
  run_ps "Get-AppxPackage -AllUsers | Where-Object { \$_.Name -match 'BingNews|BingWeather|GamingApp|GetHelp|Getstarted|MicrosoftOfficeHub|SolitaireCollection|People|PowerAutomate|Todos|WindowsAlarms|FeedbackHub|WindowsMaps|SoundRecorder|Xbox|YourPhone|ZuneMusic|ZuneVideo|QuickAssist|Teams|Clipchamp|549981C3F5F10|StickyNotes|ScreenSketch|windowscommunicationsapps|WindowsMeetNow' } | Remove-AppxPackage -ErrorAction SilentlyContinue" "Removing bloat apps" 120 || true
  run_ps "Get-AppxProvisionedPackage -Online | Where-Object { \$_.PackageName -match 'BingNews|BingWeather|GamingApp|GetHelp|Getstarted|MicrosoftOfficeHub|SolitaireCollection|People|PowerAutomate|Todos|WindowsAlarms|FeedbackHub|WindowsMaps|SoundRecorder|Xbox|YourPhone|ZuneMusic|ZuneVideo|QuickAssist|Teams|Clipchamp|549981C3F5F10|StickyNotes|ScreenSketch|windowscommunicationsapps|WindowsMeetNow' } | Remove-AppxProvisionedPackage -Online -ErrorAction SilentlyContinue" "Deprovisioning bloat (prevents reinstall)" 120 || true

  echo "Disabling telemetry and ads..." >&2
  run_ps "Set-ItemProperty -Path 'HKLM:\SOFTWARE\Policies\Microsoft\Windows\DataCollection' -Name AllowTelemetry -Value 0 -Force; New-Item -Path 'HKLM:\SOFTWARE\Policies\Microsoft\Windows\DataCollection' -Force | Out-Null; Set-ItemProperty -Path 'HKLM:\SOFTWARE\Policies\Microsoft\Windows\DataCollection' -Name AllowTelemetry -Value 0" "Disabling telemetry" || true
  run_ps "New-Item -Path 'HKLM:\SOFTWARE\Policies\Microsoft\Windows\CloudContent' -Force | Out-Null; Set-ItemProperty -Path 'HKLM:\SOFTWARE\Policies\Microsoft\Windows\CloudContent' -Name DisableWindowsSpotlightFeatures -Value 1; Set-ItemProperty -Path 'HKLM:\SOFTWARE\Policies\Microsoft\Windows\CloudContent' -Name DisableTailoredExperiencesWithDiagnosticData -Value 1; Set-ItemProperty -Path 'HKLM:\SOFTWARE\Policies\Microsoft\Windows\CloudContent' -Name DisableThirdPartySuggestions -Value 1" "Disabling ads and suggestions" || true

  echo "Disabling Copilot and widgets..." >&2
  run_ps "New-Item -Path 'HKLM:\SOFTWARE\Policies\Microsoft\Windows\WindowsCopilot' -Force | Out-Null; Set-ItemProperty -Path 'HKLM:\SOFTWARE\Policies\Microsoft\Windows\WindowsCopilot' -Name TurnOffWindowsCopilot -Value 1" "Disabling Copilot" || true
  run_ps "New-Item -Path 'HKLM:\SOFTWARE\Policies\Microsoft\Dsh' -Force | Out-Null; Set-ItemProperty -Path 'HKLM:\SOFTWARE\Policies\Microsoft\Dsh' -Name AllowNewsAndInterests -Value 0" "Disabling Widgets" || true

  echo "Disabling unnecessary services..." >&2
  run_ps "Set-Service -Name DiagTrack -StartupType Disabled -ErrorAction SilentlyContinue; Stop-Service -Name DiagTrack -Force -ErrorAction SilentlyContinue; Set-Service -Name dmwappushservice -StartupType Disabled -ErrorAction SilentlyContinue; Stop-Service -Name dmwappushservice -Force -ErrorAction SilentlyContinue" "Disabling DiagTrack and WAP Push" || true

  echo "Removing OneDrive..." >&2
  run_ps "Stop-Process -Name OneDrive -Force -ErrorAction SilentlyContinue; if (Test-Path \"\$env:SystemRoot\SysWOW64\OneDriveSetup.exe\") { Start-Process \"\$env:SystemRoot\SysWOW64\OneDriveSetup.exe\" '/uninstall' -Wait } elseif (Test-Path \"\$env:SystemRoot\System32\OneDriveSetup.exe\") { Start-Process \"\$env:SystemRoot\System32\OneDriveSetup.exe\" '/uninstall' -Wait }" "Uninstalling OneDrive" 60 || true

  echo "Disabling web search and Bing in Start menu..." >&2
  run_ps "New-Item -Path 'HKLM:\SOFTWARE\Policies\Microsoft\Windows\Explorer' -Force | Out-Null; Set-ItemProperty -Path 'HKLM:\SOFTWARE\Policies\Microsoft\Windows\Explorer' -Name DisableSearchBoxSuggestions -Value 1; New-Item -Path 'HKLM:\SOFTWARE\Policies\Microsoft\Windows' -Force | Out-Null; Set-ItemProperty -Path 'HKLM:\SOFTWARE\Policies\Microsoft\Windows' -Name DisableSearchBoxSuggestions -Value 1" "Disabling Bing search" || true

  echo "Disabling lock screen ads and Spotlight..." >&2
  run_ps "New-Item -Path 'HKLM:\SOFTWARE\Policies\Microsoft\Windows\CloudContent' -Force | Out-Null; Set-ItemProperty -Path 'HKLM:\SOFTWARE\Policies\Microsoft\Windows\CloudContent' -Name DisableWindowsSpotlightOnLockScreen -Value 1; Set-ItemProperty -Path 'HKLM:\SOFTWARE\Policies\Microsoft\Windows\CloudContent' -Name DisableWindowsSpotlightWindowsWelcomeExperience -Value 1; Set-ItemProperty -Path 'HKLM:\SOFTWARE\Policies\Microsoft\Windows\CloudContent' -Name DisableWindowsConsumerFeatures -Value 1" "Disabling Spotlight and lock screen ads" || true

  echo "Disabling Activity History..." >&2
  run_ps "Set-ItemProperty -Path 'HKLM:\SOFTWARE\Policies\Microsoft\Windows\System' -Name EnableActivityFeed -Value 0 -Force; Set-ItemProperty -Path 'HKLM:\SOFTWARE\Policies\Microsoft\Windows\System' -Name PublishUserActivities -Value 0 -Force; Set-ItemProperty -Path 'HKLM:\SOFTWARE\Policies\Microsoft\Windows\System' -Name UploadUserActivities -Value 0 -Force" "Disabling Activity History" || true

  echo "Disabling hibernation..." >&2
  run_ps "powercfg /hibernate off" "Disabling hibernation" || true

  echo "Preventing reinstall of removed apps..." >&2
  run_ps "New-Item -Path 'HKLM:\SOFTWARE\Policies\Microsoft\Windows\CloudContent' -Force | Out-Null; Set-ItemProperty -Path 'HKLM:\SOFTWARE\Policies\Microsoft\Windows\CloudContent' -Name DisableWindowsConsumerFeatures -Value 1; Set-ItemProperty -Path 'HKLM:\SOFTWARE\Policies\Microsoft\Windows\CloudContent' -Name DisableCloudOptimizedContent -Value 1; Set-ItemProperty -Path 'HKLM:\SOFTWARE\Policies\Microsoft\Windows\CloudContent' -Name DisableSoftLanding -Value 1" "Disabling Consumer Features" || true

  echo "Cleaning up Start menu and taskbar..." >&2
  run_ps "New-Item -Path 'HKLM:\SOFTWARE\Microsoft\Windows\CurrentVersion\Explorer\Advanced' -Force | Out-Null; Set-ItemProperty -Path 'HKLM:\SOFTWARE\Microsoft\Windows\CurrentVersion\Explorer\Advanced' -Name TaskbarDa -Value 0 -Force; Set-ItemProperty -Path 'HKLM:\SOFTWARE\Microsoft\Windows\CurrentVersion\Explorer\Advanced' -Name TaskbarMn -Value 0 -Force; Set-ItemProperty -Path 'HKLM:\SOFTWARE\Microsoft\Windows\CurrentVersion\Explorer\Advanced' -Name ShowTaskViewButton -Value 0 -Force; New-Item -Path 'HKLM:\SOFTWARE\Microsoft\Windows\CurrentVersion\Search' -Force | Out-Null; Set-ItemProperty -Path 'HKLM:\SOFTWARE\Microsoft\Windows\CurrentVersion\Search' -Name SearchboxTaskbarMode -Value 0 -Force" "Cleaning taskbar (hide widgets, chat, task view, search box)" || true

  # Report IP
  sleep 3
  _ip=$(sudo virsh domifaddr "$VM_NAME" --source agent 2>/dev/null | grep ipv4 | awk '{print $4}' | cut -d/ -f1 | head -1)
  echo "" >&2
  echo "Post-install complete. VM accessible at:" >&2
  echo "  SSH: ssh ${LOCAL_USER}@${_ip:-<pending>}" >&2
  echo "  RDP: ${_ip:-<pending>}:3389" >&2
fi
