#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<EOF
Usage: $0 [options]

Creates a Ubuntu LTS minimal desktop VM on KVM/libvirt with SSH enabled.
Fully unattended via cloud-init autoinstall.

Flags:
  --fresh           Wipe existing VM and recreate from scratch (implies --force)
  --force           Undefine existing domain, keep disk
  --hostname NAME   VM and hostname (default: ubuntu)
  --user NAME       Username (default: cloudgenius)
  --password PASS   Password (prompts if omitted)
  --ssh-key FILE    SSH public key file to authorize (default: ~/.ssh/id_ed25519.pub)
  --ram MiB         Memory in MiB (default: 4096)
  --vcpus N         vCPUs (default: 4)
  --disk GB         Disk size in GB (default: 60)
  --iso PATH        Ubuntu Server ISO path (auto-downloads latest LTS if omitted)
  --no-autoinstall  Skip autoinstall, do manual setup
  --post-install    Wait for VM, verify SSH access
  -h, --help        Show this help

Examples:
  $0 --fresh --password s3cret --post-install
  $0 --fresh --hostname devbox --user admin --password admin123
  $0 --post-install                                # Verify SSH on running VM
  $0 --fresh --no-autoinstall                      # Manual install
EOF
}

FORCE=0; FRESH=0; POST_INSTALL=0; NO_AUTOINSTALL=0
VM_NAME="ubuntu"
LOCAL_USER="cloudgenius"
LOCAL_PASS=""
SSH_KEY_FILE="$HOME/.ssh/id_ed25519.pub"
RAM=4096; VCPUS=4; DISK_SIZE_GB=60
ISO=""
DOWNLOAD_DIR="$HOME/Downloads"
UBUNTU_MIRROR="https://releases.ubuntu.com"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --force) FORCE=1; shift;;
    --fresh) FORCE=1; FRESH=1; shift;;
    --hostname) VM_NAME="$2"; shift 2;;
    --user) LOCAL_USER="$2"; shift 2;;
    --password) LOCAL_PASS="$2"; shift 2;;
    --ssh-key) SSH_KEY_FILE="$2"; shift 2;;
    --ram) RAM="$2"; shift 2;;
    --vcpus) VCPUS="$2"; shift 2;;
    --disk) DISK_SIZE_GB="$2"; shift 2;;
    --iso) ISO="$2"; shift 2;;
    --no-autoinstall) NO_AUTOINSTALL=1; shift;;
    --post-install) POST_INSTALL=1; shift;;
    -h|--help) usage; exit 0;;
    *) echo "Unknown arg: $1" >&2; usage; exit 1;;
  esac
done

DISK="/var/lib/libvirt/images/${VM_NAME}.qcow2"
NVRAM="/var/lib/libvirt/qemu/nvram/${VM_NAME}_VARS.fd"
CODE_FW="/etc/ovmf/OVMF_CODE.ms.fd"
VARS_TMPL="/etc/ovmf/OVMF_VARS.ms.fd"

for f in "$CODE_FW" "$VARS_TMPL"; do
  [[ -f $f ]] || { echo "Missing firmware: $f" >&2; exit 1; }
done

# Auto-detect or download Ubuntu Server LTS ISO
if [[ -z "$ISO" ]]; then
  ISO=$(ls -1 "$DOWNLOAD_DIR"/ubuntu-*-live-server-amd64.iso 2>/dev/null | sort -V | tail -n1 || true)
fi
if [[ -z "$ISO" ]]; then
  echo "No local Ubuntu Server ISO found, downloading latest LTS..." >&2
  # Try 24.04 LTS (Noble)
  _iso_name="ubuntu-24.04.2-live-server-amd64.iso"
  _iso_url="${UBUNTU_MIRROR}/24.04.2/${_iso_name}"
  echo "Downloading $_iso_name ..." >&2
  curl -fSL -o "$DOWNLOAD_DIR/$_iso_name" "$_iso_url" || {
    # Fallback: try to find latest from releases page
    echo "Direct download failed. Check https://releases.ubuntu.com for latest LTS ISO." >&2
    exit 1
  }
  ISO="$DOWNLOAD_DIR/$_iso_name"
fi
echo "Using ISO: $ISO" >&2
[[ -f "$ISO" ]] || { echo "ISO not found: $ISO" >&2; exit 1; }

# Resolve SSH key — derive .pub from private key if missing
SSH_KEY=""
for _ktype in id_ed25519 id_rsa id_ecdsa; do
  _pub="$HOME/.ssh/${_ktype}.pub"
  _priv="$HOME/.ssh/${_ktype}"
  if [[ -f "$_pub" ]]; then
    SSH_KEY_FILE="$_pub"
    break
  elif [[ -f "$_priv" ]]; then
    echo "Deriving public key from $_priv" >&2
    ssh-keygen -y -f "$_priv" > "$_pub" && chmod 644 "$_pub"
    SSH_KEY_FILE="$_pub"
    break
  fi
done
if [[ -f "$SSH_KEY_FILE" ]]; then
  SSH_KEY=$(<"$SSH_KEY_FILE")
  echo "Using SSH key: $SSH_KEY_FILE" >&2
else
  echo "No SSH key found (checked ~/.ssh/id_{ed25519,rsa,ecdsa}{,.pub})" >&2
fi

sudo install -d -m0755 /var/lib/libvirt/images
sudo install -d -m0750 /var/lib/libvirt/qemu/nvram || true

if (( FRESH )); then
  echo "Fresh: removing disk & NVRAM" >&2
  sudo rm -f "$DISK" "$NVRAM" || true
fi

if [[ ! -f "$DISK" ]]; then
  echo "Creating disk $DISK (${DISK_SIZE_GB}G)" >&2
  sudo qemu-img create -f qcow2 "$DISK" "${DISK_SIZE_GB}G" >/dev/null
fi

# Check VM state
VM_EXISTS=0; VM_RUNNING=0
if sudo virsh -c qemu:///system dominfo "$VM_NAME" &>/dev/null; then
  VM_EXISTS=1
  _state=$(sudo virsh -c qemu:///system domstate "$VM_NAME" 2>/dev/null || true)
  [[ "$_state" == *running* ]] && VM_RUNNING=1
fi

if (( VM_EXISTS && VM_RUNNING && !FORCE && !FRESH )); then
  echo "Domain $VM_NAME is already running." >&2
  if (( POST_INSTALL )); then
    :
  else
    echo "Nothing to do. Use --force to recreate, or --post-install to verify." >&2
    exit 0
  fi
elif (( VM_EXISTS && FORCE )); then
  echo "Undefining existing domain $VM_NAME" >&2
  sudo virsh -c qemu:///system destroy "$VM_NAME" &>/dev/null || true
  sudo virsh -c qemu:///system undefine "$VM_NAME" --nvram || sudo virsh -c qemu:///system undefine "$VM_NAME" || true
  VM_EXISTS=0; VM_RUNNING=0
elif (( VM_EXISTS && !VM_RUNNING && !FORCE )); then
  echo "Domain $VM_NAME exists but is stopped; starting it." >&2
  sudo virsh -c qemu:///system start "$VM_NAME"
  VM_RUNNING=1
fi

if (( !VM_EXISTS )); then

  # Generate cloud-init autoinstall seed
  SEED_ISO=""
  if (( !NO_AUTOINSTALL )); then
    if [[ -z "$LOCAL_PASS" ]]; then
      read -rsp "Enter password for $LOCAL_USER: " LOCAL_PASS; echo >&2
      if [[ -z "$LOCAL_PASS" ]]; then
        echo "Password cannot be empty." >&2; exit 1
      fi
    fi

    HASHED=$(openssl passwd -6 "$LOCAL_PASS")
    CI_DIR=$(mktemp -d /tmp/${VM_NAME}-seed-XXXX)

    # meta-data
    cat > "$CI_DIR/meta-data" <<MD
instance-id: ${VM_NAME}-$(date +%s)
local-hostname: $VM_NAME
MD

    # user-data with autoinstall
    cat > "$CI_DIR/user-data" <<UD
#cloud-config
autoinstall:
  version: 1
  locale: en_US.UTF-8
  keyboard:
    layout: us
  identity:
    hostname: $VM_NAME
    username: $LOCAL_USER
    password: '$HASHED'
  ssh:
    install-server: true
    allow-pw: true
$(if [[ -n "$SSH_KEY" ]]; then
cat <<SK
    authorized-keys:
      - $SSH_KEY
SK
fi)
  packages:
    - ubuntu-desktop-minimal
    - qemu-guest-agent
    - openssh-server
    - curl
    - git
  late-commands:
    - curtin in-target -- systemctl disable ssh.socket
    - curtin in-target -- systemctl enable ssh.service
    - curtin in-target -- mkdir -p /run/sshd
    - curtin in-target -- systemctl enable qemu-guest-agent
  storage:
    layout:
      name: lvm
      sizing-policy: all
UD

    SEED_ISO=$(mktemp /tmp/${VM_NAME}-seed-XXXX.iso)
    _mkiso=""
    if command -v genisoimage >/dev/null 2>&1; then
      _mkiso="genisoimage"
    elif command -v xorriso >/dev/null 2>&1; then
      _mkiso="xorriso -as mkisofs"
    fi
    if [[ -n "$_mkiso" ]]; then
      $_mkiso -quiet -output "$SEED_ISO" -volid CIDATA -joliet -rock \
        "$CI_DIR/user-data" "$CI_DIR/meta-data"
    else
      # NixOS: use nix-shell to get genisoimage
      nix-shell -p cdrkit --run "genisoimage -quiet -output '$SEED_ISO' -volid CIDATA -joliet -rock '$CI_DIR/user-data' '$CI_DIR/meta-data'"
    fi
    echo "Created autoinstall seed ISO" >&2
    rm -rf "$CI_DIR"
  fi

  # Build virt-install command. --location extracts kernel/initrd from
  # the ISO and --extra-args passes 'autoinstall' on the kernel cmdline,
  # which is the only reliable way to skip the "Continue with autoinstall?"
  # prompt on UEFI VMs (direct <kernel>/<cmdline> XML doesn't work with pflash).
  VIRT_CMD=(
    sudo virt-install
    --connect qemu:///system
    --name "$VM_NAME"
    --memory "$RAM"
    --vcpus "$VCPUS"
    --cpu host-passthrough
    --os-variant ubuntu24.04
    --boot uefi
    --disk "path=$DISK,format=qcow2,bus=virtio,cache=none,discard=unmap"
    --network network=br0,model=virtio
    --graphics vnc,listen=0.0.0.0
    --video qxl
    --channel unix,target.type=virtio,target.name=org.qemu.guest_agent.0
    --rng /dev/urandom
    --noautoconsole
  )

  if (( NO_AUTOINSTALL )); then
    VIRT_CMD+=(--cdrom "$ISO")
  else
    VIRT_CMD+=(--location "$ISO,kernel=casper/vmlinuz,initrd=casper/initrd")
    VIRT_CMD+=(--extra-args "autoinstall ds=nocloud")
  fi

  if [[ -n "$SEED_ISO" ]]; then
    VIRT_CMD+=(--disk "path=$SEED_ISO,device=cdrom,bus=sata,readonly=on")
  fi

  echo "Creating $VM_NAME with virt-install" >&2
  "${VIRT_CMD[@]}" || { echo "virt-install failed." >&2; exit 1; }
  echo "VM $VM_NAME started." >&2
  VM_RUNNING=1
fi

# --- Post-install ---
if (( POST_INSTALL )); then
  echo "Waiting for VM to be reachable via SSH..." >&2
  _ip=""
  for i in $(seq 1 120); do
    _ip=$(sudo virsh domifaddr "$VM_NAME" --source agent 2>/dev/null | grep ipv4 | awk '{print $4}' | cut -d/ -f1 | head -1 || true)
    if [[ -n "$_ip" ]]; then
      if ssh -o ConnectTimeout=3 -o StrictHostKeyChecking=accept-new -o BatchMode=yes "$LOCAL_USER@$_ip" true 2>/dev/null; then
        echo "" >&2
        echo "Post-install complete. VM accessible at:" >&2
        echo "  SSH: ssh ${LOCAL_USER}@${_ip}" >&2
        exit 0
      fi
    fi
    sleep 5
  done
  # Fallback: report IP even if SSH not yet ready
  if [[ -n "$_ip" ]]; then
    echo "" >&2
    echo "VM has IP $_ip but SSH not yet available (still installing?)." >&2
    echo "Try: ssh ${LOCAL_USER}@${_ip}" >&2
  else
    echo "Could not determine VM IP. Check guest agent or use virt-manager." >&2
  fi
fi
