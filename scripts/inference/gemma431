#!/run/current-system/sw/bin/bash
set -euo pipefail
export CUDA_VISIBLE_DEVICES=0

MODEL_PATH="${MODEL_PATH:-/home/cloudgenius/inference/models/gemma431/gemma-4-31B-it-UD-Q4_K_XL.gguf}"
MODEL_ALIAS="${MODEL_ALIAS:-unsloth/gemma-4-31B}"

if [[ ! -f "$MODEL_PATH" ]]; then
    echo "Error: GGUF model file not found: $MODEL_PATH" >&2
    exit 1
fi

/home/cloudgenius/inference/llama.cpp/build/bin/llama-server \
    --model "$MODEL_PATH" \
    --alias "$MODEL_ALIAS" \
    --mmproj /home/cloudgenius/inference/models/gemma431/mmproj-F16.gguf \
    --no-mmproj-offload \
    --temp 1.0 \
    --top-p 0.95 \
    --top-k 64 \
    --host 0.0.0.0 \
    --port 8001 \
    --fit off \
    --cache-type-k q4_0 --cache-type-v q4_0 \
    --flash-attn on \
    --n-gpu-layers 60 \
    --parallel 1 \
    --batch-size 2048 --ubatch-size 512 \
    --jinja \
    --reasoning off \
    --ctx-size 122880
